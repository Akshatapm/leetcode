class Solution {
    public int mirrorDistance(int n) {
        int res=Math.abs(n-reverseofn(n));
        return res;
    }
    public static int reverseofn(int n){
        int rev=0;
        while(n>0){
            int temp=n%10;
            rev=rev*10+temp;
            n/=10;
        }
        return rev;
    }
}
